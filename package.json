{
  "name": "haruki-toolbox",
  "private": true,
  "version": "7.7.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "test": "bun test",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "lint": "eslint --max-warnings=0 \"src/**/*.{ts,vue}\" \"scripts/**/*.mjs\" \"vite.config.ts\"",
    "check:imports": "bun scripts/check-imports.mjs",
    "build": "bun run check:imports && vue-tsc --noEmit && bunx --bun vite build",
    "preview": "vue-tsc --noEmit && bunx --bun vite preview",
    "typecheck": "bun run check:imports && vue-tsc --noEmit",
    "quality": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.5",
    "@unovis/vue": "^1.6.5",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "axios": "1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "vue-sonner": "^2.0.9",
    "vue3-simple-icons": "^16.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "8.0.10",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
